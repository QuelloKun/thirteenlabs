{
  "folders": [
    {
      "path": ".",
      "name": "Root"
    },
    {
      "path": "StyleTTS2",
      "name": "StyleTTS2"
    },
    {
      "path": "Make-An-Audio",
      "name": "Make-An-Audio"
    },
    {
      "path": "StyleTTS2FineTune",
